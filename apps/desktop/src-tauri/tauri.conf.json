{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "offline-md-editor-viewer",
  "identifier": "com.ishizakahiroshi.offline-md-editor-viewer",
  "build": {
    "frontendDist": "../../browser"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "offline-md-editor-viewer",
        "url": "offline-md-editor-viewer.html",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": true
      }
    ],
    "withGlobalTauri": true,
    "security": {
      "csp": "default-src 'none'; script-src 'self' 'unsafe-inline'; style-src 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src ipc: http://ipc.localhost; object-src 'none'; base-uri 'none'; form-action 'none'; frame-src 'none'"
    }
  },
  "bundle": {
    "active": false,
    "targets": ["msi", "nsis"],
    "publisher": "Hiroshi Ishizaka (ishizakahiroshi)",
    "homepage": "https://github.com/ishizakahiroshi/offline-md-editor-viewer",
    "copyright": "Copyright (c) 2026 Hiroshi Ishizaka (ishizakahiroshi)",
    "license": "MIT",
    "licenseFile": "../../../LICENSE",
    "category": "Productivity",
    "shortDescription": "Offline Markdown editor and previewer",
    "longDescription": "offline-md-editor-viewer is a local-first Markdown editor and previewer with browser and Windows desktop editions.",
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
